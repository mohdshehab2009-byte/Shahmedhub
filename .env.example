# YouTube Data API v3 — get a free key at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_api_key_here

# Your YouTube channel ID (e.g. UC_x5XG1OV2P6uZZ5FSM9Ttw) or handle (e.g. @channelname)
YOUTUBE_CHANNEL_ID=your_channel_id_here

# SoundCloud API — get a client_id by registering at https://developers.soundcloud.com/
SOUNDCLOUD_CLIENT_ID=your_client_id_here

# Your SoundCloud username (e.g. username from soundcloud.com/username)
SOUNDCLOUD_USERNAME=your_soundcloud_username
